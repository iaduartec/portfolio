{
  "name": "myinvestview",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0 --port ${PORT:-3000}",
    "dev:clean": "bash ./scripts/dev.sh",
    "build": "next build",
    "start": "PORT=${PORT:-10000} next start --hostname 0.0.0.0 --port $PORT",
    "lint": "eslint app src --max-warnings=0",
    "type-check": "tsc --noEmit",
    "check": "pnpm lint && pnpm type-check",
    "build:market-search-index": "python3 scripts/build-market-search-index.py",
    "backtest:calibration": "pnpm dlx tsx scripts/backtest-calibration.ts",
    "vercel": "pnpm dlx vercel",
    "analyze": "cross-env ANALYZE=true next build --webpack"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/openai": "^3.0.41",
    "@ai-sdk/react": "^3.0.118",
    "@radix-ui/react-slot": "^1.2.4",
    "ai": "^6.0.116",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "html2canvas": "^1.4.1",
    "lightweight-charts": "^5.1.0",
    "lucide-react": "^0.577.0",
    "marked": "^17.0.4",
    "next": "^16.1.6",
    "papaparse": "^5.5.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@next/bundle-analyzer": "^16.1.6",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/html2canvas": "^1.0.0",
    "@types/node": "^25.5.0",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "0.27.0"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
